<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#8FD9C3"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Welcome!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2C5F4F"/>

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Logout"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C5F4F"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"/>
        </LinearLayout>

        <!-- Today's Overview Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S OVERVIEW"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C5F4F"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Students -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F5F5F5"
                        android:padding="16dp"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/tvTotalStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="#2C5F4F"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Students"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:gravity="center"/>
                    </LinearLayout>

                    <!-- Present Today -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#F5F5F5"
                        android:padding="16dp"
                        android:layout_margin="4dp">

                        <TextView
                            android:id="@+id/tvPresentToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Present Today"
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/llAbsenteeList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"/>

        <!-- Reports Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REPORTS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C5F4F"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnDailyReport"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="📊 Daily Report"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C5F4F"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnMonthlyReport"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="📅 Monthly Report"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C5F4F"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Search Student Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEARCH STUDENT"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C5F4F"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etSearchStudent"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Enter name or UID"
                android:background="@android:color/white"
                android:padding="16dp"
                android:textSize="14sp"/>

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="🔍 Search"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2C5F4F"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>